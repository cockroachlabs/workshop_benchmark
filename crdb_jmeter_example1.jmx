          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="Populate Dashboard" enabled="true">
            <stringProp name="dataSource">central</stringProp>
            <stringProp name="queryType">Callable Statement</stringProp>
            <stringProp name="query">WITH tt1 AS 
(
    INSERT INTO Transactions (acct_id, mer_id, creat_dt, trans_usd_am)
    VALUES (${__threadNum}, ${__threadNum}, &apos;DT&apos;, 4.29)
      RETURNING (trans_acqr_refer_no), 
                            (acct_id), 
                             (mer_id), 
                           (creat_ts), 
                           (creat_dt),
                       (trans_usd_am)
), 
tt2 AS (
    INSERT INTO Transactions2
    SELECT tt1.trans_acqr_refer_no, tt1.acct_id, tt1.mer_id, tt1.creat_ts, tt1.creat_dt, tt1.trans_usd_am 
    FROM tt1
    RETURNING (trans_acqr_refer_no), 
                            (acct_id), 
                             (mer_id), 
                           (creat_ts), 
                           (creat_dt),
                       (trans_usd_am)      
),
ms3 as (
INSERT INTO MerchantCMDailySpend(mer_id, acct_id, creat_dt, tot_trans_usd_am, creat_ts) 
SELECT tt2.mer_id, tt2.acct_id, tt2.creat_dt, tt2.trans_usd_am, tt2.creat_ts
FROM tt2
  ON CONFLICT (mer_id, acct_id, creat_dt) 
  DO UPDATE SET 
    tot_trans_usd_am = MerchantCMDailySpend.tot_trans_usd_am + excluded.tot_trans_usd_am,
    tot_trans_ct = MerchantCMDailySpend.tot_trans_ct + 1
  RETURNING        (acct_id), 
                  (creat_dt),
          (tot_trans_usd_am), 
                  (creat_ts)
)
INSERT INTO CMDailySpend (acct_id, creat_dt, tot_trans_usd_am, creat_ts) 
SELECT ms3.acct_id, ms3.creat_dt, ms3.tot_trans_usd_am, ms3.creat_ts
FROM ms3
ON CONFLICT (acct_id, creat_dt) 
  DO UPDATE SET 
    tot_trans_usd_am = CMDailySpend.tot_trans_usd_am + excluded.tot_trans_usd_am, 
    tot_trans_ct = CMDailySpend.tot_trans_ct + 1;
--        ${__Random(0,1000)}, 
--     VALUES (${__intSum(2,threadNum)}, ${__threadNum}, &apos;DT&apos;, 4.29) </stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="variableNames"></stringProp>
            <stringProp name="resultVariable"></stringProp>
            <stringProp name="queryTimeout"></stringProp>
            <stringProp name="resultSetHandler">Store as String</stringProp>
            <stringProp name="resultSetMaxRows"></stringProp>
          </JDBCSampler>
          <hashTree/>
        </hashTree>
        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="update_low" enabled="false">
          <stringProp name="dataSource">central</stringProp>
          <stringProp name="queryType">Callable Statement</stringProp>
          <stringProp name="query">BEGIN;

SET TRANSACTION PRIORITY LOW;
--update alerts set cstatus=cstatus, updated_at=now() WHERE id=317;
--
---- MAYBE TRY CTE with Sleep to see if it repo&apos;s?
--select pg_sleep(5);

with uac as (
    update alerts set cstatus=cstatus, updated_at=now() WHERE id=317
    RETURNING (cstatus)    
),
slp as (
    select pg_sleep(1)
)
select cstatus 
from uac
join slp on (1=1);

COMMIT;</stringProp>
